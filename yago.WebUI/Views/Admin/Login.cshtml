@{
    // Bu kod, ana sayfanın üst menüsünün ve alt bilgisinin bu sayfada GÖRÜNMEMESİNİ sağlar.
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sistem Girişi - yagiztkn</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
        darkMode: 'class',
        theme: {
        extend: {
        colors: {
        accent: '#3b82f6', // Sitenin temasına uygun mavi vurgu
        }
        }
        }
        }
    </script>
</head>
<body class="bg-zinc-950 flex items-center justify-center min-h-screen font-sans selection:bg-accent selection:text-white">

    <div class="w-full max-w-md p-10 bg-zinc-900 border border-zinc-800 rounded-3xl shadow-2xl relative overflow-hidden">
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-accent/20 rounded-full blur-3xl pointer-events-none"></div>

        <div class="text-center mb-10 relative z-10">
            <h1 class="text-3xl font-bold text-white tracking-widest">YAGIZ<span class="text-accent">TKN</span></h1>
            <p class="text-zinc-500 mt-2 text-sm font-medium tracking-wide">Güvenli Yönetim Paneli</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-500/10 border border-red-500/50 text-red-400 text-sm font-medium p-4 rounded-xl mb-6 text-center animate-pulse">
                @ViewBag.Error
            </div>
        }

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 rounded-xl flex items-center gap-3 text-red-500">
                <i class="fa-solid fa-circle-exclamation text-lg"></i>
                <span class="text-sm font-medium">@ViewBag.ErrorMessage</span>
            </div>
        }

        <form asp-action="Login" asp-controller="Admin" method="post" class="flex flex-col gap-6 relative z-10">
            <div>
                <label class="block text-zinc-400 text-xs font-semibold mb-2 uppercase tracking-wider">Kullanıcı Adı</label>
                <input type="text" name="username" class="w-full bg-zinc-950 border border-zinc-800 text-white rounded-xl px-5 py-3.5 focus:outline-none focus:border-accent transition-colors" required autocomplete="off" placeholder="admin" />
            </div>
            <div>
                <label class="block text-zinc-400 text-xs font-semibold mb-2 uppercase tracking-wider">Şifre</label>
                <input type="password" name="password" class="w-full bg-zinc-950 border border-zinc-800 text-white rounded-xl px-5 py-3.5 focus:outline-none focus:border-accent transition-colors" required placeholder="••••••" />
            </div>
            <button type="submit" class="w-full bg-accent hover:bg-orange-500 text-white font-bold tracking-wide py-4 rounded-xl transition-all shadow-[0_0_20px_rgba(249,115,22,0.3)] hover:shadow-[0_0_25px_rgba(249,115,22,0.5)] mt-2">
                Sisteme Giriş Yap &rarr;
            </button>
        </form>

        <div class="mt-8 text-center relative z-10">
            <a href="/" class="text-zinc-500 hover:text-zinc-300 text-sm font-medium transition-colors">&larr; Vitrine Dön</a>
        </div>
    </div>

</body>
</html>
