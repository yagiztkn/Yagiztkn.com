@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Şifre Değiştir - Admin Paneli</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { darkMode: 'class', theme: { extend: { colors: { accent: '#3b82f6' } } } }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="bg-zinc-950 text-zinc-300 font-sans selection:bg-accent selection:text-white flex items-center justify-center min-h-screen p-6">
    
    <div class="w-full max-w-md bg-zinc-900 border border-zinc-800 rounded-2xl shadow-2xl overflow-hidden p-8">
        <div class="mb-8 text-center">
            <div class="w-16 h-16 rounded-full bg-accent/10 text-accent flex items-center justify-center mx-auto mb-4 text-2xl">
                <i class="fa-solid fa-shield-halved"></i>
            </div>
            <h1 class="text-2xl font-bold text-white mb-2">Güvenlik Ayarları</h1>
            <p class="text-zinc-500 text-sm">Yönetici şifrenizi güncellemek için aşağıdaki alanları doldurun.</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 rounded-xl flex items-center gap-3 text-red-500">
                <i class="fa-solid fa-circle-exclamation text-lg"></i>
                <span class="text-sm font-medium">@ViewBag.Error</span>
            </div>
        }

        <form asp-action="ChangePassword" asp-controller="Admin" method="post" class="flex flex-col gap-5">
            
            <div>
                <label class="block text-zinc-400 text-xs font-semibold mb-2 uppercase tracking-wider">Mevcut Şifre</label>
                <input type="password" name="currentPassword" class="w-full bg-zinc-950 border border-zinc-800 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-accent transition-colors" required />
            </div>
            
            <div class="w-full h-px bg-zinc-800 my-1"></div>
            
            <div>
                <label class="block text-zinc-400 text-xs font-semibold mb-2 uppercase tracking-wider">Yeni Şifre</label>
                <input type="password" name="newPassword" class="w-full bg-zinc-950 border border-zinc-800 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-accent transition-colors" required />
                
                <ul class="mt-3 text-xs text-zinc-500 space-y-1 ml-1">
                    <li><i class="fa-solid fa-check text-accent/70 mr-1"></i> En az 6 karakter</li>
                    <li><i class="fa-solid fa-check text-accent/70 mr-1"></i> Büyük ve küçük harf</li>
                    <li><i class="fa-solid fa-check text-accent/70 mr-1"></i> Rakam (0-9)</li>
                    <li><i class="fa-solid fa-check text-accent/70 mr-1"></i> Özel karakter (!, *, #, $, %, ^, &, *)</li>
                </ul>
            </div>
            
            <div class="flex items-center gap-4 mt-6">
                <a href="/Admin/Index" class="px-6 py-3 rounded-xl font-medium text-zinc-400 hover:text-white hover:bg-zinc-800 transition-colors">İptal</a>
                <button type="submit" class="flex-1 bg-accent hover:bg-blue-600 text-white font-bold py-3 rounded-xl transition-all shadow-[0_0_15px_rgba(59,130,246,0.3)]">
                    Şifreyi Güncelle
                </button>
            </div>
        </form>
    </div>

</body>
</html>
