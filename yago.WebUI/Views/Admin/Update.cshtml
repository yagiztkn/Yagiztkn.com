@model Yago.Core.Entities.Project // Kendi proje adını yazmayı unutma

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Projeyi Düzenle - yagiztkn</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { darkMode: 'class', theme: { extend: { colors: { accent: '#3b82f6' } } } }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="bg-zinc-950 text-zinc-300 font-sans selection:bg-accent selection:text-white flex items-center justify-center min-h-screen p-6">

    <div class="w-full max-w-2xl bg-zinc-900 border border-zinc-800 rounded-2xl shadow-2xl overflow-hidden p-8">
        <div class="mb-8">
            <h1 class="text-2xl font-bold text-white mb-2">Projeyi Düzenle</h1>
            <p class="text-zinc-500 text-sm">"@Model.Title" projesinin veritabanı kayıtlarını güncelliyorsun.</p>
        </div>

        <form asp-action="Update" asp-controller="Admin" method="post" class="flex flex-col gap-5">

            <input type="hidden" name="ID" value="@Model.ID" />

            <div>
                <label class="block text-zinc-400 text-xs font-semibold mb-2 uppercase tracking-wider">Proje Adı *</label>
                <input type="text" name="Title" value="@Model.Title" class="w-full bg-zinc-950 border border-zinc-800 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-accent transition-colors" required />
            </div>

            <div>
                <label class="block text-zinc-400 text-xs font-semibold mb-2 uppercase tracking-wider">Kısa Açıklama *</label>
                <textarea name="ShortDescription" rows="2" class="w-full bg-zinc-950 border border-zinc-800 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-accent transition-colors" required>@Model.ShortDescription</textarea>
            </div>

            <div>
                <label class="block text-zinc-400 text-xs font-semibold mb-2 uppercase tracking-wider">Kullanılan Teknolojiler *</label>
                <input type="text" name="Technologies" value="@Model.Technologies" class="w-full bg-zinc-950 border border-zinc-800 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-accent transition-colors" required />
            </div>

            <div class="w-full h-px bg-zinc-800 my-2"></div>

            <div>
                <label class="block text-zinc-400 text-xs font-semibold mb-2 uppercase tracking-wider">Detaylı Açıklama (Opsiyonel)</label>
                <textarea name="FullDescription" rows="4" class="w-full bg-zinc-950 border border-zinc-800 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-accent transition-colors">@Model.FullDescription</textarea>
            </div>

            <div class="flex gap-4">
                <div class="flex-1">
                    <label class="block text-zinc-400 text-xs font-semibold mb-2 uppercase tracking-wider">GitHub Linki (Opsiyonel)</label>
                    <input type="url" name="GitHubLink" value="@Model.GitHubLink" class="w-full bg-zinc-950 border border-zinc-800 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-accent transition-colors" />
                </div>
                <div class="flex-1">
                    <label class="block text-zinc-400 text-xs font-semibold mb-2 uppercase tracking-wider">Canlı Site Linki (Opsiyonel)</label>
                    <input type="url" name="LiveLink" value="@Model.LiveLink" class="w-full bg-zinc-950 border border-zinc-800 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-accent transition-colors" />
                </div>
            </div>

            <div class="flex items-center gap-4 mt-4 pt-6 border-t border-zinc-800">
                <a href="/Admin/Index" class="px-6 py-3 rounded-xl font-medium text-zinc-400 hover:text-white hover:bg-zinc-800 transition-colors">İptal</a>
                <button type="submit" class="flex-1 bg-accent hover:bg-blue-600 text-white font-bold py-3 rounded-xl transition-all shadow-[0_0_15px_rgba(59,130,246,0.3)]">
                    Değişiklikleri Kaydet <i class="fa-solid fa-floppy-disk ml-2"></i>
                </button>
            </div>
        </form>
    </div>

</body>
</html>
