@model Yago.Core.Entities.Project

<section class="py-32 bg-white dark:bg-zinc-950 min-h-screen">
    <div class="max-w-4xl mx-auto px-6">

        <!-- Üst Kısım: Başlık ve Teknolojiler -->
        <div class="reveal mb-12">
            <a asp-action="Index" class="text-sm font-medium text-accent hover:underline mb-8 inline-block">← Tüm Projelere Dön</a>
            <h1 class="text-4xl md:text-6xl font-bold text-zinc-900 dark:text-white mb-6 tracking-tighter">@Model.Title</h1>

            <div class="flex flex-wrap gap-2">
                @if (!string.IsNullOrEmpty(Model.Technologies))
                {
                    foreach (var tech in Model.Technologies.Split(','))
                    {
                        <span class="px-4 py-1.5 bg-zinc-100 dark:bg-zinc-900 text-zinc-600 dark:text-zinc-400 rounded-full text-xs font-bold uppercase tracking-widest">
                            @tech.Trim()
                        </span>
                    }
                }
            </div>
        </div>

        <!-- İçerik Alanı -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16">

            <!-- Sol Taraf: Uzun Açıklama -->
            <div class="md:col-span-2 reveal d1">
                <h2 class="text-xl font-bold text-zinc-900 dark:text-white mb-6">Proje Hakkında</h2>
                <div class="text-lg text-zinc-500 dark:text-zinc-400 leading-relaxed space-y-6">
                    @* FullDescription alanını burada gösteriyoruz *@
                    @Html.Raw(Model.FullDescription)
                </div>
            </div>

            <!-- Sağ Taraf: Proje Bilgileri ve Linkler -->
            <div class="reveal d2">
                <div class="sticky top-32 space-y-8">

                    <!-- Linkler -->
                    <div class="p-8 bg-zinc-50 dark:bg-zinc-900 rounded-3xl border border-zinc-100 dark:border-zinc-800">
                        <h3 class="text-sm font-bold text-zinc-900 dark:text-white uppercase tracking-widest mb-6">Bağlantılar</h3>
                        <div class="space-y-4">
                            @if (!string.IsNullOrEmpty(Model.GitHubLink))
                            {
                                <a href="@Model.GitHubLink" target="_blank" class="flex items-center justify-between group text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors">
                                    <span class="text-sm font-medium">GitHub Repo</span>
                                    <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(Model.LiveLink))
                            {
                                <a href="@Model.LiveLink" target="_blank" class="flex items-center justify-between group text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors">
                                    <span class="text-sm font-medium">Canlı Demo</span>
                                    <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                </a>
                            }
                        </div>
                    </div>

                    <!-- Tarih -->
                    <div class="px-8">
                        <h3 class="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Tamamlanma Tarihi</h3>
                        <p class="text-zinc-900 dark:text-white font-medium">@Model.CreatedDate.ToString("MMMM yyyy")</p>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>