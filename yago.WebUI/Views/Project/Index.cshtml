@model List<Yago.Core.Entities.Project>

<section class="py-32 bg-zinc-50 dark:bg-zinc-950 min-h-screen">
    <div class="max-w-6xl mx-auto px-6">
        <div class="mb-16 reveal">
            <h2 class="text-xs font-bold tracking-widest text-accent uppercase mb-3">PORTFOLYO</h2>
            <h3 class="text-5xl font-bold text-zinc-900 dark:text-white mb-6">Tüm Projeler</h3>
            <p class="text-zinc-500 dark:text-zinc-400 max-w-2xl">
                Geliştirdiğim tüm projelerin teknik detayları, mimari yaklaşımları ve kaynak kodları.
            </p>
        </div>

        <!-- Grid Yapısı -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var item in Model)
            {
                <div class="group bg-white dark:bg-zinc-900 rounded-3xl p-8 border border-zinc-100 dark:border-zinc-800 hover:border-accent/50 transition-all duration-300 reveal flex flex-col justify-between min-h-[320px]">

                    <div>
                        <!-- Teknoloji Etiketleri -->
                        <div class="flex flex-wrap gap-2 mb-6">
                            @if (!string.IsNullOrEmpty(item.Technologies))
                            {
                                foreach (var tech in item.Technologies.Split(','))
                                {
                                    <span class="text-[10px] font-bold px-2 py-1 bg-accent/10 text-accent rounded-full uppercase tracking-wider">
                                        @tech.Trim()
                                    </span>
                                }
                            }
                        </div>

                        <!-- Başlık ve Açıklama -->
                        <h4 class="text-2xl font-bold text-zinc-900 dark:text-white mb-4 group-hover:text-accent transition-colors">
                            @item.Title
                        </h4>
                        <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-4">
                            @item.ShortDescription
                        </p>
                    </div>

                    <!-- Alt Kısım: Link ve Tarih -->
                    <div class="mt-8 pt-6 border-t border-zinc-50 dark:border-zinc-800 flex items-center justify-between">
                        <a asp-controller="Project" asp-action="Details" asp-route-id="@item.ID" class="text-sm font-bold text-zinc-900 dark:text-white hover:translate-x-1 transition-transform flex items-center gap-2">
                            Projeyi İncele 
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                        </a>
                        <span class="text-xs font-medium text-zinc-400">
                            @item.CreatedDate.Year
                        </span>
                    </div>
                </div>
            }
        </div>
    </div>
</section>