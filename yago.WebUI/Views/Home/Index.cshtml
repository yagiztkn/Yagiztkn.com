                            </span>
                            <span class="text-sm">instagram.com/yagiztkn_</span>
                        </a>
                    </div>
                </div>

                <div class="reveal d2">
                    <form asp-action="SendMessage" method="post" class="space-y-6">
                        <div class="flex flex-col gap-4">
                            <div class="grid sm:grid-cols-2 gap-4">
                                <div>
                                    <label for="fname" class="block text-xs font-medium text-zinc-400 mb-1.5">Ad-Soyad <span aria-hidden="true">*</span></label>
                                    <input type="text" id="fname" name="FullName" placeholder="Yağız Tekin" required autocomplete="name"
                                           class="w-full bg-zinc-800 border border-zinc-700 text-white text-sm rounded-xl px-4 py-3 placeholder-zinc-600 focus:outline-none focus:border-accent transition-colors">
                                </div>
                                <div>
                                    <label for="femail" class="block text-xs font-medium text-zinc-400 mb-1.5">E-posta <span aria-hidden="true">*</span></label>
                                    <input type="email" id="femail" name="Email" placeholder="yagiz@sirket.com" required autocomplete="email"
                                           class="w-full bg-zinc-800 border border-zinc-700 text-white text-sm rounded-xl px-4 py-3 placeholder-zinc-600 focus:outline-none focus:border-accent transition-colors">
                                </div>
                            </div>
                            <div>
                                <label for="fsubject" class="block text-xs font-medium text-zinc-400 mb-1.5">Konu <span aria-hidden="true">*</span></label>
                                <input type="text" id="fsubject" name="Subject" placeholder="Proje sorgusu"
                                       class="w-full bg-zinc-800 border border-zinc-700 text-white text-sm rounded-xl px-4 py-3 placeholder-zinc-600 focus:outline-none focus:border-accent transition-colors">
                            </div>
                            <div>
